<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvStockCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BBRI"
                android:textColor="@color/teal_dark"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvTypeTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:background="@drawable/bg_button_teal"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"
                android:text="BUY"
                android:textColor="@color/white"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Sinyal BBRI Terbaru"
            android:textColor="@color/text_dark"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvPriceInfo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="E: 5200 • TP: 5500"
                android:textColor="@color/text_muted"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tvTierInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PREMIUM"
                android:textColor="@color/teal_primary"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp">

            <TextView
                android:id="@+id/tvPublishedAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Published: 2026-02-27 08:00"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/tvExpiresAt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Expires: 2026-02-28 08:00"
                android:textColor="#94A3B8"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="right"
            android:layout_marginTop="8dp">

            <CheckBox
                android:id="@+id/cbSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pilih untuk Blast"
                android:textSize="12sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btnDeleteSignal"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="@drawable/bg_button_white"
                android:paddingHorizontal="12dp"
                android:text="Hapus"
                android:textAllCaps="false"
                android:textColor="@color/red_sell"
                android:textSize="11sp"
                style="?android:attr/borderlessButtonStyle" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
