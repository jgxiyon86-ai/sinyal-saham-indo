<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvLogType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SIGNAL BLAST"
                android:textColor="@color/teal_dark"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLogDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentRight="true"
                android:text="2026-02-27 10:00"
                android:textColor="@color/text_muted"
                android:textSize="10sp" />
        </RelativeLayout>

        <TextView
            android:id="@+id/tvLogSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Sent to 40 recipients"
            android:textColor="@color/text_dark"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvLogAdmin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="By: Admin"
            android:textColor="@color/slate_400"
            android:textSize="10sp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>
