<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="315"
                android:endColor="#0B4EA2"
                android:startColor="#0B6BE6" />
        </shape>
    </item>
    <item android:top="120dp" android:left="-80dp">
        <shape android:shape="oval">
            <size android:width="260dp" android:height="260dp" />
            <solid android:color="#3358C3FF" />
        </shape>
    </item>
    <item android:bottom="80dp" android:right="-70dp">
        <shape android:shape="oval">
            <size android:width="220dp" android:height="220dp" />
            <solid android:color="#2247A8FF" />
        </shape>
    </item>
</layer-list>
